set -eou pipefail

./scripts/validate-local-branch.sh

if ! command -v pnpm >/dev/null 2>&1; then
  echo "❌ pnpm is required but not installed."
  exit 1
fi

pnpm run verify

echo "✅ Pre-push checks passed."
