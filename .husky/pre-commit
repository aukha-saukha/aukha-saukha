set -euo pipefail

bash ./scripts/validate-branch.sh

if ! command -v pnpm >/dev/null 2>&1; then
  echo "❌ pnpm is required but not installed."
  exit 1
fi

pnpm exec lint-staged

echo "✅ Pre-commit checks passed."
