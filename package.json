{
  "dependencies": {
    "@astrojs/react": "^5.0.4",
    "astro": "^6.1.7",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "description": "Code repository for the Aukha Saukha app",
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^9.39.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "commitizen": "^4.3.1",
    "cspell": "^10.0.0",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-astro": "^1.7.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-perfectionist": "^5.8.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-unicorn": "^64.0.0",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "markdownlint-cli2": "^0.22.0",
    "micromatch": "^4.0.8",
    "prettier": "^3.8.1",
    "prettier-plugin-astro": "^0.14.1",
    "stylelint": "^17.6.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-order": "^8.1.1",
    "typescript": "^5.9.0",
    "typescript-eslint": "^8.58.2"
  },
  "name": "aukha-saukha",
  "private": true,
  "scripts": {
    "build": "astro build",
    "check": "astro check",
    "dev": "astro dev",
    "lint": "pnpm run lint:formatting && pnpm run lint:markdown && pnpm run lint:scripts && pnpm run lint:spellings && pnpm run lint:styles",
    "lint:formatting": "prettier --list-different \"**/*.{astro,css,html,js,json,jsx,md,mdx,scss,ts,tsx}\"",
    "lint:markdown": "markdownlint-cli2",
    "lint:scripts": "eslint --cache '**/*.{astro,js,jsx,mjs,ts,tsx}'",
    "lint:spellings": "cspell --cache --cache-strategy content --no-progress .",
    "lint:styles": "stylelint --allow-empty-input '**/*.{css,scss}'",
    "preflight": "pnpm run verify && astro preview",
    "prepare": "husky",
    "preview": "astro preview",
    "test": "node -e \"console.warn('No tests implemented yet')\"",
    "test:e2e": "node -e \"console.warn('No E2E tests implemented yet')\"",
    "typecheck": "tsc --noEmit",
    "verify": "pnpm run typecheck && astro check && astro build"
  },
  "type": "module",
  "version": "1.0.0"
}
